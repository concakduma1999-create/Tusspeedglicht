-- --- 2. LOGIC BIẾN SỐ TOÀN CỤC ---
local multiplier = 16
local speedEnabled = false
local isHolding = false
local holdStart = 0

-- Cập nhật Character mỗi khi Spawn
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local RootPart = Character:WaitForChild("HumanoidRootPart")

Player.CharacterAdded:Connect(function(newChar)
	Character = newChar
	Humanoid = Character:WaitForChild("Humanoid")
	RootPart = Character:WaitForChild("HumanoidRootPart")
end)

-- Hàm kiểm tra va chạm nâng cao (Phanh giảm dần)
local function GetSpeedScale(velocity)
	local rayOrigin = RootPart.Position
	local rayDir = velocity * 0.1 -- Nhìn trước 0.1s
	
	local rayParams = RaycastParams.new()
	rayParams.FilterDescendantsInstances = {Character}
	
	local result = workspace:Raycast(rayOrigin, rayDir, rayParams)
	
	if result then
		local distance = (result.Position - rayOrigin).Magnitude
		-- Nếu khoảng cách < 10 studs, bắt đầu giảm tốc dần
		local scale = math.clamp((distance - 2) / 8, 0, 1) 
		return scale
	end
	return 1
end

-- --- 3. VÒNG LẶP CHÍNH ---
RunService.Heartbeat:Connect(function()
	if speedEnabled and Character and RootPart and Humanoid then
		if Humanoid.FloorMaterial == Enum.Material.Air then
			local moveDir = Humanoid.MoveDirection
			if moveDir.Magnitude > 0 then
				local baseVel = Vector3.new(moveDir.X * multiplier, RootPart.AssemblyLinearVelocity.Y, moveDir.Z * multiplier)
				
				-- Áp dụng phanh giảm dần
				local scale = GetSpeedScale(baseVel)
				RootPart.AssemblyLinearVelocity = Vector3.new(baseVel.X * scale, baseVel.Y, baseVel.Z * scale)
			end
		end
	end
end)

-- --- 4. HỆ THỐNG EVENT ---
MainButton.MouseButton1Down:Connect(function()
	isHolding = true
	holdStart = tick()
	task.wait(2)
	if isHolding and (tick() - holdStart >= 2) then
		MenuFrame.Visible = true
		MenuFrame.Position = UDim2.new(MainButton.Position.X.Scale, MainButton.Position.X.Offset - 50, MainButton.Position.Y.Scale, MainButton.Position.Y.Offset + 45)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isHolding = false
	end
end)

MainButton.MouseButton1Click:Connect(function()
	if tick() - holdStart < 0.5 then
		speedEnabled = not speedEnabled
		MainButton.BackgroundTransparency = speedEnabled and 0.1 or 0.7
	end
end)

OkButton.MouseButton1Click:Connect(function()
	multiplier = tonumber(TextBox.Text) or 16
	multiplier = math.clamp(multiplier, 1, 5000)
	speedEnabled = true
	MainButton.BackgroundTransparency = 0.1
	MenuFrame.Visible = false
end)

-- Kéo thả nút (Drag)
local dragging, dragInput, dragStart, startPos
MainButton.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = MainButton.Position
	end
end)
UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		MainButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)
MainButton.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)
